############ SETUP COMMANDS ############

refresh_repo_impl(){
    local repo="$1"
    cd
    cd repos
    cd "$repo"
    checkout_output=$(git checkout main 2>&1)
    git_exit_code=$?
    if [ $git_exit_code -ne 0 ]; then
        echo "unable to checkout main for repo: $repo, got $checkout_output"
        echo "please resolve manually"
        return
    fi
    pull_output=$(git pull 2>&1)
    git_exit_code=$?
    if [ $git_exit_code -ne 0 ]; then
        echo "unable to git pull main for repo $repo, got $pull_output"
        echo "please resolve manually"
        return
    fi
    echo "updated repo: $repo"
}

clone_repos() {
    cd
    if [ ! -d "$HOME/repos" ]; then
        mkdir repos
    fi
    cd repos
    if [ ! -d "llm-compressor" ]; then
        git clone https://github.com/vllm-project/llm-compressor
    fi
    if [ ! -d "compressed-tensors" ]; then
        git clone https://github.com/vllm-project/compressed-tensors
    fi
    if [ ! -d "vllm" ]; then
        git clone https://github.com/vllm-project/vllm
    fi
    if [ ! -d "speculators" ]; then
        git clone https://github.com/vllm-project/speculators
    fi
}

vllm_env_setup() {
    cd
    # Create vllm environment
    uv venv --python 3.11 vllm
    . ~/vllm/bin/activate

    uv pip install torch
    uv pip install accelerate
    uv pip install transformers
    uv pip install lm_eval
    uv pip install qwen_vl_utils
    uv pip install ray
    vllm_install_main

    echo "Created vllm environment"
    deactivate
}

rhdev_env_setup() {
    cd
    # Create rhdev environment
    uv venv --python 3.11 rhdev
    . ~/rhdev/bin/activate

    uv pip install transformers
    uv pip install accelerate
    uv pip install isort
    uv pip install pytest
    uv pip install debugpy
    uv pip install tblib
    uv pip install qwen_vl_utils
    uv pip install lm_eval
    uv pip install ray
    env_install
    
    echo "Created rhdev environment"
    deactivate
